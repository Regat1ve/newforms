# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.

# Postgres connection. Replace YOUR_POSTGRES_PASSWORD with the password
# you set when installing PostgreSQL on this machine.
DATABASE_URL="postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/newforms_dev?schema=public"

# Auth.js
# Generate one with: `pnpm dlx auth secret` (or any 32+ char random string)
AUTH_SECRET=""

# Magic-link email (Phase 1) — leave blank in dev, we use the console transport.
# In production: SMTP host/port/user/pass for transactional email.
EMAIL_SERVER=""
EMAIL_FROM="no-reply@example.com"
